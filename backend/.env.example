PORT=4000
FRONTEND_URL=http://localhost:3000

# AI providers (at least one required)
groq_Ai=your_groq_api_key_here
open_Router_ai=your_openrouter_api_key_here

# Supabase REST API
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Required for backend-generated verification and recovery links. Keep server-only.
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
# Legacy Supabase projects can use this name instead of SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# Authentication email delivery. SMTP is recommended for Vercel and Windows.
MAIL_FROM=SkillFit <no-reply@example.com>
MAIL_TRANSPORT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
# Optional for a Linux host with a local Sendmail/Postfix binary.
SENDMAIL_PATH=sendmail
# Must be present in Supabase Authentication > URL Configuration > Redirect URLs.
AUTH_REDIRECT_URL=http://localhost:3000

# Supabase direct PostgreSQL connection (for auto-migrations on local dev)
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional: Hugging Face token for embedding API (free tier works without one, but token avoids rate limits)
HUGGINGFACE_TOKEN=your_huggingface_token_here
